# Copy to .env and fill in.
# .env is gitignored.

# === Base mainnet RPC ===
# Public https://mainnet.base.org rate-limits aggressively (429 after a few
# requests). Use a private Alchemy / QuickNode / Chainstack key.
BASE_RPC_URL=

# === Hyperliquid ===
# An EOA private key (hex, with or without 0x). This account must hold USDC
# margin on Hyperliquid (deposit via CCTP from Base).
HL_PRIVATE_KEY=

# Optional: separate "API wallet" generated from the main wallet.
# Recommended for safety — limits blast radius if key leaks.
# Leave empty to use HL_PRIVATE_KEY directly for signing.
HL_API_WALLET_KEY=

# === Runtime mode ===
# true  = DEFAULT, simulates orders without submitting
# false = LIVE TRADING (real money on Hyperliquid mainnet)
DRY_RUN=true

# Position sizing cap (USD). Hard cap — agent will not exceed.
MAX_POSITION_USD=10

# Daily loss limit (USD). Agent halts trading if breached.
DAILY_LOSS_LIMIT_USD=1

# === Logging ===
LOG_LEVEL=INFO
